<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.bajiezu.cloud.customer.dal.mapper.CustomerOrderLogMapper">

    <resultMap id="BaseResultMap" type="com.bajiezu.cloud.customer.dal.entity.CustomerOrderLog">
        <id column="id" property="id"/>
        <result column="customer_id" property="customerId"/>
        <result column="msg_id" property="msgId"/>
        <result column="order_id" property="orderId"/>
        <result column="order_no" property="orderNo"/>
        <result column="status" property="status"/>
        <result column="order_time" property="orderTime"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, customer_id, msg_id, order_id, order_no, status, order_time, create_time
    </sql>

    <select id="queryCountByOrderNo" resultType="java.lang.Integer">
        select count(*) from customer_order_log
        where order_no = #{orderNo}
    </select>
</mapper>