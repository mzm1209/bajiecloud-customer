<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.bajiezu.cloud.customer.dal.mapper.CustomerMapper">

    <resultMap id="BaseResultMap" type="com.bajiezu.cloud.customer.dal.entity.Customer">
        <id column="id" property="id"/>
        <result column="platform_uid" property="platformUid"/>
        <result column="third_party_id" property="thirdPartyId"/>
        <result column="platform_name" property="platformName"/>
        <result column="source_channel" property="sourceChannel"/>
        <result column="source_level" property="sourceLevel"/>
        <result column="source_point" property="sourcePoint"/>
        <result column="mobile" property="mobile"/>
        <result column="email" property="email"/>
        <result column="wechat_id" property="wechatId"/>
        <result column="wechat_mobile" property="wechatMobile"/>
        <result column="id_card" property="idCard"/>
        <result column="id_card_hash" property="idCardHash"/>
        <result column="nickname" property="nickname"/>
        <result column="avatar_url" property="avatarUrl"/>
        <result column="real_name" property="realName"/>
        <result column="gender" property="gender"/>
        <result column="birthday" property="birthday"/>
        <result column="area_code" property="areaCode"/>
        <result column="member_level" property="memberLevel"/>
        <result column="in_black_list" property="inBlackList"/>
        <result column="in_black_reason" property="inBlackReason"/>
        <result column="is_anonymous" property="isAnonymous"/>
        <result column="account_status" property="accountStatus"/>
        <result column="merge_master_id" property="mergeMasterId"/>
        <result column="last_login_time" property="lastLoginTime"/>
        <result column="last_login_ip" property="lastLoginIp"/>
        <result column="order_count" property="orderCount"/>
        <result column="last_order_time" property="lastOrderTime"/>
        <result column="last_source" property="lastSource"/>
        <result column="version" property="version"/>
        <result column="emergency_contact_name" property="emergencyContactName"/>
        <result column="create_by" property="createBy"/>
        <result column="updated_by" property="updatedBy"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <result column="is_deleted" property="isDeleted"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, platform_uid, third_party_id, platform_name, source_channel, source_level, source_point,
        mobile, email, wechat_id, wechat_mobile, id_card, id_card_hash, nickname, avatar_url, real_name,
        gender, birthday, area_code, member_level, in_black_list, in_black_reason, is_anonymous,
        account_status, merge_master_id, last_login_time, last_login_ip, order_count, last_order_time, last_source, version,
        emergency_contact_name, create_by, updated_by, create_time, update_time, is_deleted
    </sql>

    <select id="queryByIds" resultMap="BaseResultMap">
        select * from customer
        where is_deleted = 0 and
        id in
        <foreach item="item" collection="customerIds" separator="," open="(" close=")" index="index">
            #{item}
        </foreach>
    </select>

    <update id="updateByBlack">
        update customer set in_black_list = #{isBlack}, in_black_reason = #{blackReason},
                            updated_by = #{updateBy}, update_time = #{updateTime}
        where id in
        <foreach item="item" collection="customerIds" separator="," open="(" close=")" index="index">
            #{item}
        </foreach>
    </update>

    <select id="queryListBy" resultMap="BaseResultMap" parameterType="com.bajiezu.cloud.customer.dal.dto.CustomerListDto">
        select * from customer
        <include refid="queryListCondition"/>
        order by create_time desc
        limit #{offset},#{limit}
    </select>

    <select id="queryCountBy" resultType="java.lang.Long" parameterType="com.bajiezu.cloud.customer.dal.dto.CustomerListDto">
        select count(*) from customer
        <include refid="queryListCondition"/>
    </select>

    <sql id="queryListCondition">
        where is_deleted = 0
        <if test="mobile != null and mobile != ''">
            and mobile = #{mobile}
        </if>
        <if test="name != null and name != ''">
            and nickname like concat('%',#{name},'%')
        </if>
        <if test="customerId != null">
            and id = #{customerId}
        </if>
        <if test="memberLevels != null and memberLevels.size() > 0">
            and member_level in
            <foreach item="item" collection="memberLevels" separator="," open="(" close=")" index="index">
                #{item}
            </foreach>
        </if>
        <if test="platformNames != null and platformNames.size() > 0">
            and platform_name in
            <foreach item="item" collection="platformNames" separator="," open="(" close=")" index="index">
                #{item}
            </foreach>
        </if>
        <if test="isBlackCustomer != null">
            and in_black_list = #{isBlackCustomer}
        </if>
    </sql>

    <select id="queryListByMobile" resultMap="BaseResultMap">
        select * from customer
        where is_deleted = 0 and mobile like concat(#{mobile},'%')
        order by create_time desc
        limit #{offset},#{limit}
    </select>

    <select id="queryCountByMobile" resultType="java.lang.Long">
        select count(*) from customer
        where is_deleted = 0 and mobile like concat(#{mobile},'%')
    </select>
</mapper>