<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.bajiezu.cloud.customer.dal.mapper.CustomerLogMapper">

    <resultMap id="BaseResultMap" type="com.bajiezu.cloud.customer.dal.entity.CustomerLog">
        <id column="id" property="id"/>
        <result column="customer_id" property="customerId"/>
        <result column="operate_type" property="operateType"/>
        <result column="operator_id" property="operatorId"/>
        <result column="action_desc" property="actionDesc"/>
        <result column="create_by" property="createBy"/>
        <result column="updated_by" property="updatedBy"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <result column="is_deleted" property="isDeleted"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, customer_id, operate_type, operator_id, action_desc, create_by, updated_by, create_time, update_time, is_deleted
    </sql>

    <insert id="batchInsert">
        insert into customer_log
            (customer_id, operate_type, operator_id, action_desc, create_by, updated_by, create_time, update_time, is_deleted)
        values
        <foreach collection="list" item="item" separator=",">
            (#{item.customerId}, #{item.operateType}, #{item.operatorId}, #{item.actionDesc}, #{item.createBy}, #{item.updatedBy}, #{item.createTime}, #{item.updateTime}, #{item.isDeleted})
        </foreach>
    </insert>

</mapper>